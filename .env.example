# =========================================
# ElderPing — Root Environment Variables
# Copy this file to .env and fill in values
# =========================================

# JWT
JWT_SECRET=change_me_to_a_long_random_secret

# Auth DB
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=change_me
AUTH_DB_NAME=users_db

# Health DB
HEALTH_DB_HOST=health-db
HEALTH_DB_PORT=5432
HEALTH_DB_USER=postgres
HEALTH_DB_PASSWORD=change_me
HEALTH_DB_NAME=health_db

# Reminder DB
REMINDER_DB_HOST=reminder-db
REMINDER_DB_PORT=5432
REMINDER_DB_USER=postgres
REMINDER_DB_PASSWORD=change_me
REMINDER_DB_NAME=reminder_db

# Alert DB
ALERT_DB_HOST=alert-db
ALERT_DB_PORT=5432
ALERT_DB_USER=postgres
ALERT_DB_PASSWORD=change_me
ALERT_DB_NAME=alert_db
